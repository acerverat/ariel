// Configuracion de infraestructura de Nextflow.
// Los parametros del flujo de trabajo se definen en params.yaml.

// Directorio de trabajo de Nextflow
workDir = ""

// Configuracion de los contenedores de Docker
docker {
  runOptions = '-u $(id -u):$(id -g)'
  enabled    = true
  temp       = 'auto'
  fixOwnership = true
}

// Configuracion de los modulos
process {
  errorStrategy = 'ignore'
}
